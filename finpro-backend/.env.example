# ─────────────────────────────────────────────
#  FinanPro — Variables de Entorno
#  Copia este archivo a .env y completa los valores
# ─────────────────────────────────────────────

# SERVIDOR
NODE_ENV=development
PORT=3001

# BASE DE DATOS PostgreSQL
# Railway: pega la DATABASE_URL que te dan automáticamente
# Render:  igual, la encuentras en la sección "Environment"
DATABASE_URL=postgresql://usuario:contraseña@localhost:5432/finpro_db

# Para producción Railway/Render, solo necesitas:
# DATABASE_URL=postgresql://...  (ellos la proveen)

# JWT
JWT_SECRET=cambia_este_secreto_por_uno_largo_y_aleatorio_min_32_chars
JWT_EXPIRES_IN=8h

# TWILIO — SMS y WhatsApp (mora)
# Obtén gratis en: https://www.twilio.com/try-twilio
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_PHONE_FROM=+1234567890
# Para WhatsApp usa el sandbox de Twilio:
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# EMPRESA (para PDFs y contratos)
EMPRESA_NOMBRE=FinanPro S.R.L.
EMPRESA_RNC=1-23-45678-9
EMPRESA_DIRECCION=Av. Principal #123, Santo Domingo, RD
EMPRESA_TELEFONO=809-555-0100
EMPRESA_EMAIL=info@finpro.com.do

# FRONTEND URL (para CORS)
FRONTEND_URL=http://localhost:5173

# MORA — Tasa de penalidad por día (0.3% del capital pendiente)
MORA_TASA_DIARIA=0.003
# Días de gracia antes de aplicar penalidad
MORA_DIAS_GRACIA=1
